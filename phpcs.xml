<?xml version="1.0"?>
<ruleset name="Sugar and Spice Theme">
  <description>WordPress Coding Standards for the Sugar and Spice theme.</description>

  <file>.</file>

  <exclude-pattern>*/.git/*</exclude-pattern>
  <exclude-pattern>*/.github/*</exclude-pattern>
  <exclude-pattern>*/vendor/*</exclude-pattern>
  <exclude-pattern>*/node_modules/*</exclude-pattern>
  <exclude-pattern>*/languages/*</exclude-pattern>
  <exclude-pattern>*/fonts/*</exclude-pattern>
  <exclude-pattern>*/images/*</exclude-pattern>
  <exclude-pattern>*/js/*.min.js</exclude-pattern>

  <arg name="basepath" value="."/>
  <arg name="colors"/>
  <arg name="extensions" value="php"/>
  <arg name="parallel" value="4"/>
  <arg name="cache" value=".phpcs-cache"/>
  <arg value="sp"/>

  <config name="testVersion" value="8.1-"/>

  <rule ref="WordPress"/>
  <rule ref="WordPress-Extra"/>
  <rule ref="WordPress-Docs"/>

  <rule ref="WordPress.WP.I18n">
    <properties>
      <property name="text_domain" type="array">
        <element value="sugarspice"/>
      </property>
    </properties>
  </rule>

  <rule ref="Generic.Files.LineLength">
    <properties>
      <property name="lineLimit" value="120"/>
      <property name="absoluteLineLimit" value="0"/>
    </properties>
    <exclude name="Generic.Files.LineLength.TooLong"/>
  </rule>

  <rule ref="WordPress.Security.EscapeOutput"/>
  <rule ref="WordPress.Security.ValidatedSanitizedInput"/>

  <!--
    Keep strict_types declarations at the top of PHP files.
    PSR-12 expects the file docblock immediately after the opening tag, which
    conflicts with declare(strict_types=1); in this theme baseline.
  -->
  <rule ref="PSR12.Files.FileHeader">
    <exclude name="PSR12.Files.FileHeader.IncorrectOrder"/>
  </rule>

  <!--
    Do not fail the build on CRLF/LF mismatches while normalizing this legacy
    codebase incrementally. Mixed endings are still visible as warnings.
  -->
  <rule ref="Generic.Files.LineEndings">
    <exclude name="Generic.Files.LineEndings.InvalidEOLChar"/>
  </rule>

  <!--
    File docblocks are not enforced globally to avoid noisy failures on legacy
    template files while the codebase is being standardized. Function-level and
    API documentation rules remain enabled through WordPress-Docs.
  -->
  <rule ref="Squiz.Commenting.FileComment">
    <exclude name="Squiz.Commenting.FileComment.Missing"/>
    <exclude name="Squiz.Commenting.FileComment.SpacingAfterComment"/>
  </rule>

  <!--
    Legacy theme templates still contain many historical inline comments. We do
    not want punctuation-only failures to hide more important security and API
    issues during the migration.
  -->
  <rule ref="Squiz.Commenting.InlineComment">
    <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
  </rule>

  <!--
    Intentionally disabled for now.

    In a classic WordPress theme, local variables used inside template files are
    routinely flagged by this sniff even though they are not real exported
    globals. Enabling it at this stage creates a lot of false-positive noise in
    header/footer/archive templates and makes the report less actionable.

    Re-enable this once template files have been normalized or once the rule is
    narrowed to real theme globals/functions only.
  -->
  <!-- <exclude name="WordPress.NamingConventions.PrefixAllGlobals"/> -->

  <!--
    This theme intentionally preserves legacy lowercase widget class names and
    existing file names to avoid breaking saved widget instances and long-lived
    theme conventions. WPCS naming expectations for modern class files are not a
    good fit for this backward-compatible codebase.
  -->
  <rule ref="WordPress.Files.FileName">
    <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
  </rule>

  <rule ref="PEAR.NamingConventions.ValidClassName">
    <exclude name="PEAR.NamingConventions.ValidClassName.StartWithCapital"/>
    <exclude name="PEAR.NamingConventions.ValidClassName.Invalid"/>
  </rule>

  <!--
    Long template strings and HTML-heavy markup routinely exceed 120 characters
    in classic WordPress themes. Keep the configured limit for local guidance,
    but do not fail CI on line-length-only noise.
  -->
  <!--
    Alignment-only warnings are cosmetic and generate disproportionate noise in
    legacy templates after automated normalization.
  -->
  <rule ref="Generic.Formatting.MultipleStatementAlignment">
    <exclude name="Generic.Formatting.MultipleStatementAlignment.NotSameWarning"/>
  </rule>

  <rule ref="Universal.WhiteSpace.PrecisionAlignment">
    <exclude name="Universal.WhiteSpace.PrecisionAlignment.Found"/>
  </rule>

  <!--
    Mixed line ending warnings are not actionable once invalid EOL characters no
    longer fail the build.
  -->
  <rule ref="Internal.LineEndings">
    <exclude name="Internal.LineEndings.Mixed"/>
  </rule>
</ruleset>
